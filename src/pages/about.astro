---
export const prerender = false;

import Layout from "../layouts/BlogPost.astro";

const site = Astro.locals.site;
---

<Layout
	title="About these reviews"
	description={`How ${site.companyName} reviews are collected and published.`}
	pubDate={new Date("2026-05-24")}
	heroImage="/blog-placeholder-about.jpg"
>
	<p>
		This site collects and publishes customer reviews of {site.shopUrl ? (
			<a href={site.shopUrl} target="_blank" rel="noopener">{site.companyName}</a>
		) : (
			site.companyName
		)}. We aggregate reviews from across the web — the company's own site and trusted
		third-party platforms — into one place so shoppers can see the full picture.
	</p>

	<p>
		Every review here comes from a real customer. We publish them as-is: ratings span the
		full one-to-five-star scale, and we don't hide critical feedback. Where a review came
		from a particular platform, we link back to the original.
	</p>

	<p>
		Spotted something inaccurate, or want to share your own experience with {site.companyName}?
		Get in touch and we'll take a look.
	</p>
</Layout>
