---
import type { Review } from "../db/schema";
import FormattedDate from "./FormattedDate.astro";
import StarRating from "./StarRating.astro";

interface Props {
	review: Review;
}

const { review } = Astro.props;
---

<article class="review-card">
	<header class="card-head">
		<StarRating rating={review.rating} />
		{review.verified && (
			<span class="verified" title="Verified purchase">✓ Verified purchase</span>
		)}
	</header>
	{review.title && <h3 class="card-title">{review.title}</h3>}
	<p class="card-body">{review.body}</p>
	<footer class="card-meta">
		<span class="author">
			{review.authorName}{review.authorLocation && (
				<span class="location">, {review.authorLocation}</span>
			)}
		</span>
		<span class="sep">·</span>
		<FormattedDate date={review.reviewedAt} />
		{review.product && (
			<>
				<span class="sep">·</span>
				<span class="product">{review.product}</span>
			</>
		)}
	</footer>
</article>

<style>
	.review-card {
		padding: 1.5em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		background: #fff;
		box-shadow: 0 2px 6px rgba(var(--gray), 8%);
	}
	.card-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
		margin-bottom: 0.5em;
	}
	.verified {
		font-size: 0.8rem;
		font-weight: 700;
		color: #1a7f4b;
		white-space: nowrap;
	}
	.card-title {
		font-size: 1.25em;
		margin: 0 0 0.4em 0;
	}
	.card-body {
		margin: 0 0 1em 0;
		color: rgb(var(--gray-dark));
	}
	.card-meta {
		font-size: 0.9rem;
		color: rgb(var(--gray));
	}
	.author {
		font-weight: 700;
		color: rgb(var(--gray-dark));
	}
	.location,
	.product {
		font-weight: 400;
	}
	.sep {
		margin: 0 0.4em;
	}
</style>
