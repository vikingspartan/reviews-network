---
import HeaderLink from "./HeaderLink.astro";
import { SHOP_URL, SITE_TITLE } from "../consts";
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/reviews">Reviews</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="shop-link">
			<a href={SHOP_URL} target="_blank" rel="noopener">Shop Memorygram →</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.shop-link a {
		font-weight: 700;
		color: var(--accent);
		white-space: nowrap;
	}
	@media (max-width: 720px) {
		.shop-link {
			display: none;
		}
	}
</style>
