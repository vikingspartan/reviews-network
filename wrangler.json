{
	"name": "memorygram-reviews",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"routes": [
		{ "pattern": "storyworthreviews.com", "custom_domain": true },
		{ "pattern": "www.storyworthreviews.com", "custom_domain": true },
		{ "pattern": "rementoreviews.com", "custom_domain": true },
		{ "pattern": "www.rementoreviews.com", "custom_domain": true }
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true
}
