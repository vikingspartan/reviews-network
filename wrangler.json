{
	"name": "reviews-network",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"routes": [
		{ "pattern": "storyworthreviews.com", "custom_domain": true },
		{ "pattern": "www.storyworthreviews.com", "custom_domain": true },
		{ "pattern": "rementoreviews.com", "custom_domain": true },
		{ "pattern": "www.rementoreviews.com", "custom_domain": true },
		{ "pattern": "mylifeinabookreviews.com", "custom_domain": true },
		{ "pattern": "www.mylifeinabookreviews.com", "custom_domain": true }
	],
	"kv_namespaces": [
		{ "binding": "SESSION", "id": "acfb230726394193a6bc2a74ea4a0fe6" }
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true
}
