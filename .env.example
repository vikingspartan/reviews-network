# Neon Postgres connection string for the memorygram-reviews database.
# Copy this file to `.env` and fill in the value from the Neon console
# (https://console.neon.tech) → your project → Connection Details.
# Used by Node tooling: drizzle-kit and scripts/import-reviews.ts.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?channel_binding=require&sslmode=require"

# Optional: official source-API credentials for review ingestion (`npm run ingest`).
# The Reddit and mock connectors need no key; these activate the API-based ones.
# TRUSTPILOT_API_KEY="..."
# GOOGLE_PLACES_API_KEY="..."
