# Neon Postgres connection string for the reviews-network database.
# Copy this file to `.env` and fill in the value from the Neon console
# (https://console.neon.tech) → your project → Connection Details.
# Used by Node tooling: drizzle-kit and scripts/import-reviews.ts.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?channel_binding=require&sslmode=require"

# Optional: official source-API credentials for review ingestion (`npm run ingest`).
# The mock, reddit, and trustpilot connectors need no key; this activates Google.
# GOOGLE_PLACES_API_KEY="..."

# Trustpilot fronts its pages with an AWS WAF JS challenge, so live fetches need
# Bright Data. Preferred: the Web Unlocker API, which solves the challenge
# server-side (set both vars below — the connector uses it when present).
# BRIGHT_DATA_UNLOCKER_ZONE="web_unlocker1"
# BRIGHT_DATA_API_KEY="..."   # Bright Data → account menu → API keys
#
# Fallback only: a residential proxy (gives a residential IP but can't solve the
# WAF challenge, so it 403s on Trustpilot today). Used by other sources / non-WAF pages.
# Bright Data superproxy form: http://brd-customer-<id>-zone-<zone>:<password>@brd.superproxy.io:33335
# BRIGHT_DATA_PROXY_URL="..."
