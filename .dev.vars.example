# Local Cloudflare Worker vars for `npm run dev` / `npm run preview`.
# Copy this file to `.dev.vars` and fill in the value.
# In production, set this as a Worker secret: `wrangler secret put DATABASE_URL`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?channel_binding=require&sslmode=require"

# Password for the /admin review manager.
# Production: `wrangler secret put ADMIN_PASSWORD`.
ADMIN_PASSWORD="choose-a-strong-password"
